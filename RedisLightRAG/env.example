# LightRAG with Qwen 3 and Redis Configuration
# Copy this file to .env and adjust values as needed

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=9621
WORKERS=4
LOG_LEVEL=INFO

# ============================================
# Workspace Configuration
# ============================================
WORKSPACE=default

# ============================================
# LLM Configuration (Ollama + Qwen 3)
# ============================================
LLM_PROVIDER=ollama
OLLAMA_API_BASE=http://ollama:11434
LLM_MODEL=qwen3:8b
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0
LLM_TOP_P=0.9

# Alternative Qwen 3 model sizes (comment/uncomment as needed)
# LLM_MODEL=qwen3:4b
# LLM_MODEL=qwen3:14b
# LLM_MODEL=qwen3:32b

# ============================================
# Embedding Configuration (Ollama + Qwen 3 Embedding)
# ============================================
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:8b
EMBEDDING_DIM=1024
EMBEDDING_MAX_TOKEN_SIZE=8192

# Alternative Qwen 3 Embedding model sizes
# EMBEDDING_MODEL=qwen3-embedding:0.6b
# EMBEDDING_DIM=512
# EMBEDDING_MODEL=qwen3-embedding:4b
# EMBEDDING_DIM=1024

# ============================================
# Storage Configuration
# ============================================

# KV Storage - Redis
LIGHTRAG_KV_STORAGE=RedisKVStorage
REDIS_KV_URL=redis://redis:6379
REDIS_KV_DB=0

# Document Status Storage - Redis
LIGHTRAG_DOC_STATUS_STORAGE=RedisDocStatusStorage
REDIS_DOC_STATUS_URL=redis://redis:6379
REDIS_DOC_STATUS_DB=1

# Vector Storage Options:
# Option 1: NanoVectorDB (default, in-memory, fast but not persistent)
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

# Option 2: Redis Vector Storage (persistent, recommended for production)
# LIGHTRAG_VECTOR_STORAGE=RedisVectorStorage
# REDIS_VECTOR_URL=redis://redis:6379
# REDIS_VECTOR_DB=2
# REDIS_VECTOR_INDEX_NAME=lightrag_vectors

# Graph Storage - NetworkX (default, file-based)
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage

# Alternative Graph Storage Options:
# LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
# NEO4J_URL=bolt://neo4j:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# ============================================
# Working Directory
# ============================================
WORKING_DIR=/app/data

# ============================================
# Redis Configuration
# ============================================
REDIS_MAX_MEMORY=4gb
REDIS_EVICTION_POLICY=noeviction

# ============================================
# Query Configuration
# ============================================
# Query modes: naive, local, global, hybrid, mix
DEFAULT_QUERY_MODE=hybrid

# ============================================
# Advanced Configuration
# ============================================
# Enable reranker for better retrieval (optional)
# ENABLE_RERANKER=true
# RERANKER_MODEL=dengcao/Qwen3-Reranker-4B

# Chunk size for document processing
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=100

# Number of top-k entities to retrieve
# TOP_K=10

# Enable caching
# ENABLE_CACHE=true
